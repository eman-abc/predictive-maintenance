# MLflow (local default)
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=predictive_maintenance
# Register pickles to MLflow Model Registry after Phase 3 (1=yes, 0=skip)
MLFLOW_REGISTER_MODELS=1

# Databricks MLflow (Colab or local: set URI to databricks + host + PAT with mlflow scope)
# MLFLOW_TRACKING_URI=databricks
# MLFLOW_EXPERIMENT_NAME=/Shared/predictive_maintenance
# DATABRICKS_HOST=https://dbc-xxxxxxxx.cloud.databricks.com
# DATABRICKS_TOKEN=
# Optional — run links without API (from experiment URL in Databricks UI):
# MLFLOW_EXPERIMENT_ID=2311620089394370
# Optional — link to pickle upload run (Artifacts tab) without API:
# MLFLOW_PKL_BUNDLE_RUN_ID=d33506a96f6e41e1a4144ca50b701b2f
# MLFLOW_PKL_BUNDLE_RUN_NAME=cmapss_pkl_bundle_v2
# Unity Catalog Model Registry — run: python scripts/diagnose_databricks_registry.py
# (do NOT use "main" unless it appears in your Catalog Explorer)
# MLFLOW_UC_CATALOG=your_catalog_from_ui
# MLFLOW_UC_SCHEMA=your_schema_from_ui

# Ollama / LLM briefings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=300
OLLAMA_NUM_PREDICT=120
OLLAMA_NUM_PREDICT_METRICS=320
OLLAMA_NUM_PREDICT_METRICS_SUMMARY=450
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.85
OLLAMA_NUM_CTX=2048
OLLAMA_KEEP_ALIVE=30m
OLLAMA_PRELOAD_ON_STARTUP=true

# Alert thresholds
ALERT_RUL_CRITICAL=10
ALERT_RUL_WARNING=30
ALERT_FAILURE_PROB_CRITICAL=0.85
ALERT_FAILURE_PROB_WARNING=0.60

# CMMS mock API
CMMS_API_URL=http://localhost:8080/api/workorders
CMMS_API_KEY=your-api-key-here

# CMMS work orders → Databricks Delta table (audit log for interviews)
CMMS_LOG_TO_DATABRICKS=false
# Full table name OR catalog + schema + table name:
# Use a catalog you see in Catalog Explorer (often workspace, not main):
CMMS_DELTA_TABLE=workspace.cmapss.cmms_work_orders
# Separate Delta table for auto-dispatched critical alerts (no button):
CMMS_AUTO_DELTA_TABLE=workspace.cmapss.cmms_work_orders_auto
CMMS_AUTO_DISPATCH=true
# CMMS_DELTA_CATALOG=workspace
# CMMS_DELTA_SCHEMA=cmapss
# CMMS_DELTA_TABLE_NAME=cmms_work_orders
# SQL warehouse (SQL → SQL Warehouses → Connection details → HTTP path or ID):
# From SQL Warehouses → Connection details (Serverless Starter Warehouse example):
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/654e1642cb780bc9
DATABRICKS_SQL_WAREHOUSE_ID=654e1642cb780bc9

# Data paths
CMAPSS_DATA_DIR=./data/raw/cmapss
AI4I_DATA_DIR=./data/raw/ai4i
PROCESSED_DATA_DIR=./data/processed
