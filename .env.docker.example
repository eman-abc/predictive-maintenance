# Copy to .env before: docker compose up --build
# Do not commit .env (tokens).

OLLAMA_MODEL=llama3.2
OLLAMA_PRELOAD_ON_STARTUP=true
OLLAMA_NUM_PREDICT=120
OLLAMA_NUM_PREDICT_METRICS=320
OLLAMA_NUM_PREDICT_METRICS_SUMMARY=450

# Optional Databricks CMMS audit log (API service reads these)
CMMS_LOG_TO_DATABRICKS=false
CMMS_DELTA_TABLE=workspace.cmapss.cmms_work_orders
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# MLflow links on Model Metrics page
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_ID=
