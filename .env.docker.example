# Copy to .env before: docker compose up --build
# The API container loads this file — CMMS → Databricks runs there (not in Streamlit).
# Do not commit .env (contains PAT).

# --- Ollama (API container talks to ollama service) ---
OLLAMA_MODEL=llama3.2
OLLAMA_PRELOAD_ON_STARTUP=true
OLLAMA_NUM_PREDICT=120
OLLAMA_NUM_PREDICT_METRICS=320
OLLAMA_NUM_PREDICT_METRICS_SUMMARY=200
OLLAMA_METRICS_TIMEOUT=90
CMMS_DATABRICKS_TIMEOUT_SECONDS=25
API_CMMS_TIMEOUT_SECONDS=35
API_METRICS_TIMEOUT_SECONDS=90

# --- CMMS work orders → Databricks Delta (required for demo) ---
CMMS_LOG_TO_DATABRICKS=true
CMMS_DELTA_TABLE=workspace.cmapss.cmms_work_orders
CMMS_AUTO_DELTA_TABLE=workspace.cmapss.cmms_work_orders_auto
CMMS_AUTO_DISPATCH=true
# From SQL Warehouses → Connection details:
DATABRICKS_HOST=https://dbc-bbbb280e-70f3.cloud.databricks.com
DATABRICKS_TOKEN=your-pat-with-sql-scope
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/654e1642cb780bc9
DATABRICKS_SQL_WAREHOUSE_ID=654e1642cb780bc9

# PAT must include scope: SQL (not MLflow-only). Create under
# User Settings → Developer → Access tokens.

# --- MLflow links on Model Metrics (optional) ---
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_ID=

# --- Mock CMMS REST (optional; real path is Databricks audit log) ---
CMMS_API_URL=http://localhost:8080/api/workorders
CMMS_API_KEY=
